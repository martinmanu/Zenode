{
  "name": "@zenode/serializer",
  "version": "3.5.10",
  "description": "Pure state transformations and export functions for Zenode",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@zenode/core": "workspace:*",
    "fast-xml-parser": "^5.5.11",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/js-yaml": "^4.0.9",
    "rollup": "^4.37.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  },
  "author": "Manu Martin",
  "license": "Zenode License, MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martinmanu/Zenode.git",
    "directory": "packages/serializer"
  },
  "homepage": "https://zenode-designer.vercel.app"
}
